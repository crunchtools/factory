# GitHub token — needs read access to crunchtools org repos
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read), packages:read
GH_TOKEN=ghp_REPLACE_ME

# GitHub org to auto-discover repos from (default: crunchtools)
# GITHUB_ORG=crunchtools

# Zabbix trapper target (defaults shown)
# ZABBIX_SERVER=127.0.0.1
# ZABBIX_PORT=10051

# Zabbix API — enables item coverage check (dimension 6)
# Create an API token at: Zabbix → Users → API tokens
# ZABBIX_API_URL=http://127.0.0.1:8090/api_jsonrpc.php
# ZABBIX_API_TOKEN=

# Status JSON file path (default: /data/factory-status.json)
# STATUS_FILE=/data/factory-status.json

# Dashboard HTTP port (default: 8095)
# DASHBOARD_PORT=8095
