# GitHub token — needs read access to crunchtools org repos
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read), packages:read
GH_TOKEN=ghp_REPLACE_ME

# Zabbix trapper target (defaults shown)
# ZABBIX_SERVER=127.0.0.1
# ZABBIX_PORT=10051

# Check interval in seconds (default: 900 = 15 minutes)
# WATCHDOG_INTERVAL=900
